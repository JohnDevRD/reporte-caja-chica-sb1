# =============================================================================
# Reporte de Caja Chica — Configuración de entorno
# Copiá este archivo como .env y ajustá los valores según tu entorno.
# =============================================================================

# ---------------------------------------------------------------------------
# API de datos
# ---------------------------------------------------------------------------
# URL base del endpoint que provee los datos de caja chica.
API_BASE=http://localhost:8000/api-reportes-sb1/api/v1/consultas/caja_chica/reporte.php

# Tiempo máximo de espera para cada llamada a la API (segundos).
API_TIMEOUT=30

# Tiempo máximo de conexión al servidor API (segundos).
API_CONNECT_TIMEOUT=10

# Verificar certificado SSL en la conexión a la API (true/false).
# En entornos de desarrollo con certificados autofirmados, usar false.
API_SSL_VERIFY=false

# ---------------------------------------------------------------------------
# Paginación
# ---------------------------------------------------------------------------
# Cantidad de registros por página por defecto.
DEFAULT_LIMIT=100

# Máximo de registros por página (usado en barridos completos para filtros).
MAX_LIMIT=500

# Mínimo de registros por página.
MIN_LIMIT=1

# ---------------------------------------------------------------------------
# Aplicación
# ---------------------------------------------------------------------------
# Nombre de la aplicación (se muestra en el título y navbar).
APP_NAME="Reporte de Caja Chica"

# Subtítulo que aparece debajo del nombre en la navbar.
APP_SUBTITLE="Consulta y seguimiento de movimientos"

# Modo debug (true/false). Muestra errores detallados en pantalla.
APP_DEBUG=false
